<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Honua.Collect.App.Capture.PhotoAnnotationPage"
             Title="Annotate Photo">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="10">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
            <Button x:Name="RedButton" Grid.Column="0" Text="Red" Clicked="OnPickRed" />
            <Button x:Name="YellowButton" Grid.Column="1" Text="Yellow" Clicked="OnPickYellow" />
            <Button x:Name="BlackButton" Grid.Column="2" Text="Black" Clicked="OnPickBlack" />
            <Label x:Name="ColorLabel" Grid.Column="3" VerticalOptions="Center" HorizontalTextAlignment="End" />
        </Grid>

        <Border Grid.Row="1" Stroke="LightGray" StrokeThickness="1" BackgroundColor="Black">
            <GraphicsView x:Name="Canvas"
                          StartInteraction="OnStart"
                          DragInteraction="OnDrag"
                          EndInteraction="OnEnd" />
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <Label x:Name="StatusLabel" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Undo" Clicked="OnUndo" />
            <Button Grid.Column="2" Text="Cancel" Clicked="OnCancel" />
            <Button Grid.Column="3" Text="Save" Clicked="OnSave" />
        </Grid>

    </Grid>

</ContentPage>
