<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Honua.Collect.App.Capture.InkCapturePage"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" Padding="12" RowSpacing="10">

        <Border Grid.Row="0" Stroke="LightGray" StrokeThickness="1" BackgroundColor="White">
            <GraphicsView x:Name="Canvas"
                          StartInteraction="OnStart"
                          DragInteraction="OnDrag"
                          EndInteraction="OnEnd" />
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <Label x:Name="StatusLabel" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Clear" Clicked="OnClear" />
            <Button Grid.Column="2" Text="Cancel" Clicked="OnCancel" />
            <Button Grid.Column="3" Text="Save" Clicked="OnSave" />
        </Grid>

    </Grid>

</ContentPage>
