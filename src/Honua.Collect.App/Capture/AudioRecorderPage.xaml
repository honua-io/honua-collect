<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Honua.Collect.App.Capture.AudioRecorderPage"
             Title="Record audio">

    <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

        <Label x:Name="StatusLabel" Text="Tap record to start." HorizontalOptions="Center" FontSize="16" />

        <Button x:Name="RecordButton" Text="● Record" Clicked="OnToggleRecord"
                HorizontalOptions="Center" WidthRequest="200" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Text="Cancel" Clicked="OnCancel" />
            <Button x:Name="SaveButton" Grid.Column="1" Text="Save" Clicked="OnSave" IsEnabled="False" />
        </Grid>

    </VerticalStackLayout>

</ContentPage>
