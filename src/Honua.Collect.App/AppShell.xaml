<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Honua.Collect.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Honua.Collect.App"
    xmlns:views="clr-namespace:Honua.Collect.App.Views"
    Title="Honua Collect">

    <TabBar>
        <ShellContent Title="Capture" Route="capture"
                      ContentTemplate="{DataTemplate local:MainPage}" />
        <ShellContent Title="Records" Route="records"
                      ContentTemplate="{DataTemplate views:RecordsPage}" />
        <ShellContent Title="Geometry" Route="geometry"
                      ContentTemplate="{DataTemplate views:GeometryCapturePage}" />
        <ShellContent Title="Signature" Route="signature"
                      ContentTemplate="{DataTemplate views:SignaturePage}" />
    </TabBar>

</Shell>
