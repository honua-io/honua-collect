<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Production default: cleartext HTTP is denied; all traffic must be HTTPS.
        Cleartext is permitted ONLY for local-development hosts (the Android
        emulator's host loopback and localhost), so the demo against the local
        e2e server works without weakening real deployments.
    -->
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
