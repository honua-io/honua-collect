<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Honua.Collect.App.Views.SignaturePage"
             Title="Signature">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="10">
        <Label Grid.Row="0" Text="Sign below" />
        <Border Grid.Row="1" Stroke="LightGray" StrokeThickness="1">
            <GraphicsView x:Name="Canvas"
                          StartInteraction="OnStart"
                          DragInteraction="OnDrag"
                          EndInteraction="OnEnd" />
        </Border>
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <Label x:Name="StatusLabel" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Clear" Clicked="OnClear" />
            <Button Grid.Column="2" Text="Done" Clicked="OnDone" />
        </Grid>
    </Grid>

</ContentPage>
